{
    "domain": "govee_light_ble",
    "name": "GOVEE Bluetooth Lights",
    "bluetooth": [
        { "local_name": "Govee_*", "connectable": true },
        { "local_name": "ihoment_*", "connectable": true },
        { "local_name": "GBK_*", "connectable": true }
    ],
    "codeowners": ["@Tansien"],
    "config_flow": true,
    "dependencies": ["bluetooth"],
    "documentation": "https://github.com/Tansien/hass-govee_light_ble",
    "integration_type": "device",
    "iot_class": "local_polling",
    "issue_tracker": "https://github.com/Tansien/hass-govee_light_ble/issues",
    "requirements": ["bleak-retry-connector"],
    "version": "2.7.8"
}
